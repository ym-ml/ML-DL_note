 optimizer.zero_grad()\n            X, y = X.to(device), y.to(device)\n            y_hat = net(X)\n            l = loss(y_hat, y)\n            l.backward()\n            optimizer.step()\n            with torch.no_grad():\n                metric.add(l * X.shape[0], d2l.accuracy(y_hat, y), X.shape[0])\n            timer.stop()\n            train_l = metric[0] / metric[2]\n            train_acc = metric[1] / metric[2]\n            if (i + 1) % (num_batches // 5) == 0 or i == num_batches - 1:\n                animator.add(epoch + (i + 1) / num_batches,\n                             (train_l, train_acc, None))\n        test_acc = d2l.evaluate_accuracy_gpu(net, test_iter)\n        animator.add(epoch + 1, (None, None, test_acc))\n    print(f'loss {train_l:.3f}, train acc {train_acc:.3f}, '\n          f'test acc {test_acc:.3f}')\n    print(f'{metric[2] * num_epochs / timer.sum():.1f} examples/sec \\n'\n          f'total time {timer.sum():.2f}  '\n          f'on {str(device)}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-21T11:34:50.568884Z","iopub.execute_input":"2026-03-21T11:34:50.569192Z","iopub.status.idle":"2026-03-21T11:34:50.578120Z","shell.execute_reply.started":"2026-03-21T11:34:50.569167Z","shell.execute_reply":"2026-03-21T11:34:50.577329Z"}},"outputs":[],"execution_count":30},{"cell_type":"code","source":"from torchvision.transforms import v2 as transforms_v2 ","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-21T12:08:42.904769Z","iopub.execute_input":"2026-03-21T12:08:42.905121Z","iopub.status.idle":"2026-03-21T12:08:43.045231Z","shell.execute_reply.started":"2026-03-21T12:08:42.905090Z","shell.execute_reply":"2026-03-21T12:08:43.044345Z"}},"outputs":[],"execution_count":65},{"cell_type":"code","source":"\ndef load_data_fashion_mnist(batch_size, resize=None, num_workers=4):\n    # 工作目录下的数据根（torchvision 会在 /kaggle/working 下创建 FashionMNIST 文件夹）\n    work_root = \"/kaggle/working\"\n    work_data_dir = os.path.join(work_root, \"FashionMNIST\")\n    \n    # 永久数据集目录（如果用户已上传）\n    persistent_data_dir = \"/kaggle/input/FashionMNIST\"\n    \n    # 辅助函数：检查数据是否已存在且有效（包含 raw 或 processed 子目录）\n    def is_data_valid(path):\n        return os.path.exists(path) and (\n            os.path.exists(os.path.join(path, \"raw\")) or\n            os.path.exists(os.path.join(path, \"processed\"))\n        )\n    \n    # 如果工作目录下已有有效数据，直接使用\n    if is_data_valid(work_data_dir):\n        print(\"数据已存在于工作目录，直接加载。\")\n    else:\n        # 检查永久数据集是否存在\n        if is_data_valid(persistent_data_dir):\n            print(\"从永久数据集复制到工作目录...\")\n            # 如果工作目录下已有目录（可能为空），先删除\n            if os.path.exists(work_data_dir):\n                shutil.rmtree(work_data_dir)\n            # 复制永久数据集到工作目录\n            shutil.copytree(persistent_data_dir, work_data_dir)\n            print(\"复制完成。\")\n        else:\n            print(\"未找到永久数据集，将从网络下载到工作目录。\")\n            print(\"下载中...\")\n            # 临时下载到工作目录，torchvision 会在 work_root 下创建 FashionMNIST\n            trans_dummy = transforms.Compose([transforms.ToTensor()])\n            # 下载训练集，仅触发下载\n            _ = torchvision.datasets.FashionMNIST(\n                root=work_root, train=True, transform=trans_dummy, download=True)\n            print(\"下载完成。\")\n            print(\"=\"*60)\n            print(\"请将以下文件夹上传为 Kaggle 数据集，并附加到本 Notebook：\")\n            print(f\"  路径: {work_data_dir}\")\n            print(\"上传后，下次运行时将自动从永久数据集复制，避免重复下载。\")\n            print(\"=\"*60)\n    \n    # ---------- 优化后的数据处理部分 ----------\n    # 使用 v2 构建高效预处理流水线（CPU 执行，但性能优于旧版 transforms）\n    # 注意：v2.ToImage() + v2.ToDtype(scale=True) 等同于 ToTensor()，但速度更快且支持批量操作\n    transform_steps = [\n        transforms_v2.ToImage(),                     # PIL Image / np.ndarray → torch.Tensor (形状 HWC)\n        transforms_v2.ToDtype(torch.float32, scale=True)  # 像素值缩放到 [0, 1]\n    ]\n    if resize:\n        # 在转张量之前进行 resize（对 PIL 图像操作更高效）\n        transform_steps.insert(0, transforms_v2.Resize(resize))\n    \n    transform = transforms_v2.Compose(transform_steps)\n    \n    # 加载数据集（此时工作目录下已有数据）\n    mnist_train = torchvision.datasets.FashionMNIST(\n        root=work_root, train=True, transform=transform, download=False)\n    mnist_test = torchvision.datasets.FashionMNIST(\n        root=work_root, train=False, transform=transform, download=False)\n    \n    # 创建高性能 DataLoader\n    # - persistent_workers: 保持 worker 进程存活，避免每个 epoch 重新启动（减少 CPU 开销）\n    # - prefetch_factor: 每个 worker 预取 2 个 batch，隐藏数据加载延迟\n    # - pin_memory: 固定内存，加速 CPU→GPU 传输\n    train_loader = DataLoader(\n        mnist_train, batch_size=batch_size, shuffle=True,\n        num_workers=num_workers, pin_memory=True,\n        prefetch_factor=2, persistent_workers=(num_workers > 0)\n    )\n    test_loader = DataLoader(\n        mnist_test, batch_size=batch_size, shuffle=False,\n        num_workers=num_workers, pin_memory=True,\n        prefetch_factor=2, persistent_workers=(num_workers > 0)\n    )\n    \n    return train_loader, test_loader","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-21T12:57:51.964516Z","iopub.execute_input":"2026-03-21T12:57:51.965292Z","iopub.status.idle":"2026-03-21T12:57:51.976347Z","shell.execute_reply.started":"2026-03-21T12:57:51.965252Z","shell.execute_reply":"2026-03-21T12:57:51.975554Z"}},"outputs":[],"execution_count":83},{"cell_type":"code","source":"batch_size = 256\ntrain_iter, test_iter = load_data_fashion_mnist(batch_size)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-21T12:11:05.384346Z","iopub.execute_input":"2026-03-21T12:11:05.384739Z","iopub.status.idle":"2026-03-21T12:11:05.479942Z","shell.execute_reply.started":"2026-03-21T12:11:05.384710Z","shell.execute_reply":"2026-03-21T12:11:05.479157Z"}},"outputs":[{"name":"stdout","text":"数据已存在于工作目录，直接加载。\n","output_type":"stream"}],"execution_count":69},{"cell_type":"code","source":"net = nn.Sequential(\n    \n    nn.Conv2d(1, 96, kernel_size=7, stride=3, padding=1), nn.ReLU(),\n    nn.MaxPool2d(kernel_size=3, stride=2),\n    \n   \n    nn.Conv2d(96, 256, kernel_size=5, padding=2), nn.ReLU(), #256,3,3\n    nn.MaxPool2d(kernel_size=3, stride=1, padding=1), #3-3+2+1\n    \n    # 使用三个连续的卷积层和较小的卷积窗口。\n    # 除了最后的卷积层，输出通道的数量进一步增加。\n    # 在前两个卷积层之后，汇聚层不用于减少输入的高度和宽度\n    nn.Conv2d(256, 384, kernel_size=3, padding=1), nn.ReLU(),\n    nn.Conv2d(384, 384, kernel_size=3, padding=1), nn.ReLU(),\n    nn.Conv2d(384, 256, kernel_size=3, padding=1), nn.ReLU(),\n    nn.MaxPool2d(kernel_size=3, stride=2),  \n    \n    nn.Flatten(),\n    # 这里，全连接层的输出数量是LeNet中的好几倍。使用dropout层来减轻过拟合\n    nn.Linear(256, 2048), nn.ReLU(),\n    nn.Dropout(p=0.5),\n    nn.Linear(2048, 1024), nn.ReLU(),\n    nn.Dropout(p=0.5),\n    \n    # 最后是输出层。由于这里使用Fashion-MNIST，所以用类别数为10，而非论文中的1000\n    nn.Linear(1024, 10))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-21T12:11:12.883613Z","iopub.execute_input":"2026-03-21T12:11:12.884158Z","iopub.status.idle":"2026-03-21T12:11:12.939509Z","shell.execute_reply.started":"2026-03-21T12:11:12.884124Z","shell.execute_reply":"2026-03-21T12:11:12.938714Z"}},"outputs":[],"execution_count":70},{"cell_type":"code","source":"X = torch.randn(1, 1, 28, 28)\nfor layer in net:\n    X=layer(X)\n    print(layer.__class__.__name__,'output shape:\\t',X.shape)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-21T12:11:13.458975Z","iopub.execute_input":"2026-03-21T12:11:13.459821Z","iopub.status.idle":"2026-03-21T12:11:13.475440Z","shell.execute_reply.started":"2026-03-21T12:11:13.459787Z","shell.execute_reply":"2026-03-21T12:11:13.474789Z"}},"outputs":[{"name":"stdout","text":"Conv2d output shape:\t torch.Size([1, 96, 8, 8])\nReLU output shape:\t torch.Size([1, 96, 8, 8])\nMaxPool2d output shape:\t torch.Size([1, 96, 3, 3])\nConv2d output shape:\t torch.Size([1, 256, 3, 3])\nReLU output shape:\t torch.Size([1, 256, 3, 3])\nMaxPool2d output shape:\t torch.Size([1, 256, 3, 3])\nConv2d output shape:\t torch.Si